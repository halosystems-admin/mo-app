# --- Server ---
PORT=3001
NODE_ENV=development

# --- Session ---
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Optional but recommended: persistent server sessions (connect-pg-simple).
# Use your Postgres connection string (e.g. Supabase / Heroku Postgres).
# If unset, the server falls back to in-memory sessions (not recommended for production).
DATABASE_URL=

# --- Google OAuth 2.0 (optional if using Microsoft) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth 2.0 (required if not using Google) ---
# Create an app registration in Azure AD (Microsoft Entra ID)
# Docs: https://learn.microsoft.com/entra/identity-platform/
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret

# --- SharePoint Target (optional; used when microsoftStorageMode=sharepoint) ---
# When using SharePoint storage, set a fixed site + drive/library via env.
# MS_SHAREPOINT_SITE_ID=...
# MS_SHAREPOINT_DRIVE_ID=...
MS_SHAREPOINT_SITE_ID=
MS_SHAREPOINT_DRIVE_ID=

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional: multimodal vision model for Smart Context (wounds/scans). Default: gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash
# Optional explicit backup model. Leave unset to disable secondary model attempts.
# GEMINI_VISION_FALLBACK_MODEL=

# --- Deepgram (optional) ---
# Medical transcription. Falls back to Gemini if not set.
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- Cumulative clinical history PDF (required for Smart Context “Save to record”) ---
# Filename for the cumulative notes PDF in each patient’s “Patient Notes” folder (OneDrive/Drive).
# If it already exists → new content is merged in. If not → first save creates this file.
# Example: CUMULATIVE_HISTORY_PDF_NAME=Cumulative clinical history.pdf
CUMULATIVE_HISTORY_PDF_NAME=

# --- Supabase (optional — app runs without it until you wire features) ---
# Paste real values into .env (not committed). Do not put the service role key in any VITE_* variable.
#
# Browser (Vite): client uses anon key only — client/src/lib/supabaseClient.ts
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
#
# Server (Node): optional admin client — server/services/supabaseAdmin.ts
# SUPABASE_URL=          # usually same project URL as VITE_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=
#
# After keys are set, we still need your product decisions: which tables to use, RLS policies,
# and whether auth is Supabase Auth or “session cookie only”. Share schema SQL or table names when ready.

# --- URLs ---
# Frontend URL: SPA origin (CORS + post-login redirect). On Heroku (API serves the SPA), set to the
# same public https origin users open in the browser (custom domain or *.herokuapp.com — not mixed).
CLIENT_URL=http://localhost:5173
# PRODUCTION_URL: canonical https origin for OAuth redirect_uri (.../api/auth/callback). Must match
# Google Cloud / Azure "Authorized redirect URIs" exactly. If unset in production, the app derives
# redirect_uri from the request Host (works when you only use one hostname). If env is wrong vs the
# browser host, the session cookie from /login-url will not be sent on /callback → "OAuth state mismatch."
# PRODUCTION_URL=https://your-domain.com
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Multi-user bootstrap (one-time) ---
# Run: npm run bootstrap:admin
# This will upsert an admin user into public.app_users (do NOT commit real values).
BOOTSTRAP_ADMIN_EMAIL=
# Min 12 chars. Never print this value anywhere.
BOOTSTRAP_ADMIN_PASSWORD=
# Halo Firebase user_id used for templates (defaults to HALO_USER_ID if set).
BOOTSTRAP_ADMIN_HALO_USER_ID=
BOOTSTRAP_ADMIN_FIRST_NAME=Mo
BOOTSTRAP_ADMIN_LAST_NAME=
