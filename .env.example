# --- Server ---
PORT=3001
NODE_ENV=development

# --- Session ---
# REQUIRED: Generate a strong random secret (e.g. openssl rand -hex 32)
SESSION_SECRET=

# --- Google OAuth 2.0 (optional if using Microsoft) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft OAuth 2.0 (required if not using Google) ---
# Create an app registration in Azure AD (Microsoft Entra ID)
# Docs: https://learn.microsoft.com/entra/identity-platform/
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret

# --- SharePoint Target (optional; used when microsoftStorageMode=sharepoint) ---
# When using SharePoint storage, set a fixed site + drive/library via env.
# MS_SHAREPOINT_SITE_ID=...
# MS_SHAREPOINT_DRIVE_ID=...
MS_SHAREPOINT_SITE_ID=
MS_SHAREPOINT_DRIVE_ID=

# --- Google Gemini AI ---
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Deepgram (optional) ---
# Medical transcription. Falls back to Gemini if not set.
# Get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# --- URLs ---
# Frontend URL (used for CORS and OAuth redirect)
CLIENT_URL=http://localhost:5173
# Production URL (used for OAuth redirect in production)
# PRODUCTION_URL=https://your-domain.com
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
