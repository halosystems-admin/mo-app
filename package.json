{
  "name": "halo-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:server": "nodemon --exec ts-node server/index.ts",
    "dev:client": "cd client && npm run dev",
    "dev": "echo \"Client dev server: http://localhost:5173\" && concurrently \"npm run dev:server\" \"wait-on http://localhost:3001/api/health && npm run dev:client\"",
    "build": "cd client && npm run build && cd .. && tsc",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js",
    "bootstrap:admin": "ts-node server/scripts/bootstrapAdmin.ts",
    "heroku-postbuild": "npm install --include=dev && cd client && npm install --include=dev && cd .. && npm run build",
    "test:calendar": "ts-node server/tests/calendar-normalise.test.ts"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.103.0",
    "cors": "^2.8.6",
    "docx": "^9.5.1",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "googleapis": "^171.4.0",
    "bcryptjs": "^3.0.2",
    "connect-pg-simple": "^10.0.0",
    "mammoth": "^1.11.0",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
